{application, sketch_lustre, [
    {vsn, "1.0.3"},
    {applications, [gleam_stdlib,
                    gleeunit,
                    lustre,
                    plinth,
                    sketch]},
    {description, "A Sketch runtime package, made to work with Lustre!"},
    {modules, [sketch@internals@ffi,
               sketch@lustre,
               sketch@lustre@element,
               sketch@lustre@element@html]},
    {registered, []}
]}.
